rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ──────────────────────────────────────────────
    // PUBLIC COLLECTIONS — anyone can read (guests included)
    // ──────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // NOTE: The app uses 'homepageBanners' as the Firestore collection name
    match /homepageBanners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // NOTE: The app uses 'config/shipping' for shipping settings
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // USER PROFILES — owner can read/write their own, admin can read all
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // User sub-collections (carts, favorites stored under users)
    match /users/{userId}/{subcollection=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ──────────────────────────────────────────────
    // ORDERS — authenticated users can create/read, admin can update/delete
    // ──────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // PICKUP POINTS — anyone can read, admin can write
    // ──────────────────────────────────────────────
    match /pickupPoints/{pointId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // OPTION TEMPLATES — admin writes, authenticated reads
    // ──────────────────────────────────────────────
    match /optionTemplates/{templateId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
